{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    "github>alexander-zimmermann/homelab//.renovate/autoMerge.json5",
    "github>alexander-zimmermann/homelab//.renovate/customManagers.json5",
    "github>alexander-zimmermann/homelab//.renovate/grafanaDashboards.json5",
    "github>alexander-zimmermann/homelab//.renovate/groups.json5",
    "github>alexander-zimmermann/homelab//.renovate/labels.json5",
    "github>alexander-zimmermann/homelab//.renovate/semanticCommits.json5",
    ":dependencyDashboard",
    ":disableRateLimiting",
    ":gitSignOff",
    ":semanticCommits",
    ":timezone(Europe/Berlin)"
  ],
  "dependencyDashboardTitle": "Renovate Dashboard 🤖",
  "suppressNotifications": ["prEditedNotification", "prIgnoreNotification"],
  "ignorePaths": ["**/resources/**", "**/deprecated/**"],
  "kubernetes": {
    "managerFilePatterns": ["/\\.yaml$/"]
  },
  "flux": {
    "managerFilePatterns": ["/\\.yaml$/"]
  },
  "packageRules": [
    {
      "matchFileNames": ["infrastructure/manifest/20-image/image.yaml"],
      "postUpgradeTasks": {
        "commands": [
          "python3 .github/scripts/update_versions.py",
          "python3 .github/scripts/update_checksums.py talos"
        ],
        "fileFilters": [
          "infrastructure/manifest/20-image/image.yaml",
          "infrastructure/manifest/40-template/template-vm.yaml",
          "infrastructure/manifest/50-fleet/fleet-vm.yaml"
        ],
        "executionMode": "branch"
      }
    }
  ]
}
