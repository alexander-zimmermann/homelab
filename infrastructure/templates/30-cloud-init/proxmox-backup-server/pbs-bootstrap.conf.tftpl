## Configuration file for Proxmox Backup Server
## Generated by OpenTofu (infrastructure/templates/30-cloud-init/proxmox-backup-server/config/pbs.conf.tftpl)

## Passowrd for root
PBS_ROOT_PASSWORD="${pbs_root_password}"

## Initial & Backup user
PBS_INITIAL_USERNAME="${pbs_initial_username}"
PBS_INITIAL_PASSWORD="${pbs_initial_password}"
PBS_BACKUP_USERNAME="${pbs_backup_username}"
PBS_BACKUP_PASSWORD ="${pbs_backup_password}"

## Define primary datastore (local - nvme)
DATASTORE_PRIMARY_NAME="datastore-primary"
DATASTORE_PRIMARY_PATH="/mnt/datastore-primary"

## Define secondary datastore (remote - nfs)
DATASTORE_SECONDARY_NAME="datastore-secondary"
DATASTORE_SECONDARY_PATH="/mnt/datastore-secondary"

## Data rentaion policy for primary datastore
PRIMARY_KEEP_LAST=7
PRIMARY_KEEP_DAILY=0
PRIMARY_KEEP_WEEKLY=0
PRIMARY_KEEP_MONTHLY=0
PRIMARY_KEEP_YEARLY=0

## Data rentaion policy for secondary datastore
SECONDARY_KEEP_LAST=0
SECONDARY_KEEP_HOURLY=0
SECONDARY_KEEP_DAILY=7
SECONDARY_KEEP_WEEKLY=4
SECONDARY_KEEP_MONTHLY=6
SECONDARY_KEEP_YEARLY=1

## Cloudflare convenience variables
ACME_CF_ACCOUNT_ID="${acme_cf_account_id}"
ACME_CF_ZONE_ID="${acme_cf_zone_id}"
ACME_CF_TOKEN="${acme_cf_token}"

## ACME account
ACME_ACCOUNT="letsencrypt-prod"
ACME_DIRECTORY="https://acme-v02.api.letsencrypt.org/directory"
ACME_EMAIL="alexander@zimmermann.eu.com"

## ACME DNS plugin
ACME_DNS_PLUGIN_ID="cloudflare"
ACME_DNS_ID="cf"
ACME_DNS_PLUGIN_DATA="CF_Account_ID=$${ACME_CF_ACCOUNT_ID},CF_Zone_ID=$${ACME_CF_ZONE_ID},CF_Token=$${ACME_CF_TOKEN}"

## Primary and SAN domains for ACME certificates
ACME_PRIMARY_DOMAIN="backup-01.zimmermann.eu.com"
ACME_SAN_DOMAINS="backup.zimmermann.eu.com"
ACME_DOMAINS="$${ACME_PRIMARY_DOMAIN},$${ACME_SAN_DOMAINS}"
