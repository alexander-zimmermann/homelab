## Proxmox API for shutdown orchestration
PVE_API_URL="https://pve-1.zimmermann.eu.com:8006"
PVE_NODE_NAME="pve-1"
PVE_API_TOKEN_ID="${pve_api_token_id}"
PVE_API_TOKEN_SECRET="${pve_api_token_secret}"
