## Configuration file for apcupsd UPS Monitor
## Generated by OpenTofu

## UPS connection settings
APCUPSD_UPSTYPE="usb"
APCUPSD_DEVICE=""
APCUPSD_UPSNAME="homelab-ups"

## Network Information Server (NIS)
APCUPSD_NISIP="0.0.0.0"
APCUPSD_NISPORT="3551"

## Power event thresholds
APCUPSD_BATTERYLEVEL="10"
APCUPSD_MINUTES="5"
